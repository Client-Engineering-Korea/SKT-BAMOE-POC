  <decision name="_D000000296_EntryCOND" id="_D296_ENTRY_DECISION">
    <description>D296 진입조건</description>
    <variable name="_D000000296_EntryCOND" id="_D296_ENTRY_VAR" typeRef="ValidationError" />
    <informationRequirement id="_D296_ENTRY_REQ">
      <requiredInput href="#_D296_INPUT_DATA" />
