        <outputEntry id="_D296_E_R2_OUT_4">
          <text>&quot;STOP&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
