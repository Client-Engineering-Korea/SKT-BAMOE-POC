          <text>&quot;INFO&quot;</text>
        </inputEntry>
        <inputEntry id="_D296_R3_IN_2">
          <text>&quot;Y&quot;</text>
        </inputEntry>
        <outputEntry id="_D296_R3_OUT_1">
          <text>&quot;D000000296&quot;</text>
        </outputEntry>
        <outputEntry id="_D296_R3_OUT_2">
