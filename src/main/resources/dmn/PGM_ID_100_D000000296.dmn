        <outputEntry id="_D296_R3_OUT_3">
          <text>&quot;POS미처리_대상여부체크&quot;</text>
        </outputEntry>
        <outputEntry id="_D296_R3_OUT_4">
          <text>&quot;INFO&quot;</text>
