      <output id="_D296_E_OUT_4" name="severity" typeRef="string" />
      <annotation name="Annotations" />
      <rule id="_D296_E_RULE_1">
        <inputEntry id="_D296_E_R1_IN_1">
          <text>&quot;0&quot;</text>
        </inputEntry>
        <inputEntry id="_D296_E_R1_IN_2">
          <text>not(&quot;A1&quot;)</text>
        </inputEntry>
        <outputEntry id="_D296_E_R1_OUT_1">
          <text>&quot;D000000296&quot;</text>
        </outputEntry>
        <outputEntry id="_D296_E_R1_OUT_2">
          <text>&quot;진입조건 충족&quot;</text>
        </outputEntry>
        <outputEntry id="_D296_E_R1_OUT_3">
          <text>&quot;POS미처리_대상여부체크&quot;</text>
        </outputEntry>
        <outputEntry id="_D296_E_R1_OUT_4">
          <text>&quot;INFO&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
      <rule id="_D296_E_RULE_2">
        <inputEntry id="_D296_E_R2_IN_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="_D296_E_R2_IN_2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_D296_E_R2_OUT_1">
          <text>&quot;D000000296&quot;</text>
        </outputEntry>
        <outputEntry id="_D296_E_R2_OUT_2">
