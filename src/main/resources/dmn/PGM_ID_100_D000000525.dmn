<?xml version="1.0" encoding="UTF-8" ?>
<definitions xmlns="https://www.omg.org/spec/DMN/20240513/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20230324/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/" xmlns:kie="https://kie.org/dmn/extensions/1.0" expressionLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/" namespace="https://kie.apache.org/dmn/_B31E8A0F-88E3-4F98-B19B-AF475354D932" id="_D525_DEFINITIONS" name="_D000000525">
  <description>D000000525 애플워치 자회선 개통 진행중 체크 - 모회선 변경 제한</description>
  <itemDefinition id="_D525_VE_DEF" name="ValidationError" isCollection="false" typeLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/">
    <itemComponent id="_D525_VE_C1" name="condDtlTypId"><typeRef>string</typeRef></itemComponent>
    <itemComponent id="_D525_VE_C2" name="errorCode"><typeRef>string</typeRef></itemComponent>
    <itemComponent id="_D525_VE_C3" name="errorMessage"><typeRef>string</typeRef></itemComponent>
    <itemComponent id="_D525_VE_C4" name="ruleName"><typeRef>string</typeRef></itemComponent>
    <itemComponent id="_D525_VE_C5" name="severity">
      <typeRef>string</typeRef>
      <typeConstraint id="_D525_VE_C5_CONST" kie:constraintType="enumeration">
        <text>&quot;STOP&quot;, &quot;WARN&quot;, &quot;INFO&quot;</text>
      </typeConstraint>
    </itemComponent>
  </itemDefinition>
  <decision name="_D000000525" id="_D525_DECISION">
    <variable name="_D000000525" id="_D525_DECISION_VAR" typeRef="ValidationError" />
    <informationRequirement id="_D525_REQ">
      <requiredInput href="#_D525_INPUT_DATA" />
    </informationRequirement>
    <decisionTable id="_D525_TABLE" typeRef="ValidationError" hitPolicy="UNIQUE" label="_D000000525">
      <input id="_D525_IN_1">
        <inputExpression id="_D525_IN_1_EXPR" typeRef="string">
          <text>input.externals.isAppleWatchActivationInProgressExt</text>
        </inputExpression>
      </input>
      <output id="_D525_OUT_1" name="condDtlTypId" typeRef="string" />
      <output id="_D525_OUT_2" name="errorMessage" typeRef="string" />
      <output id="_D525_OUT_3" name="ruleName" typeRef="string" />
      <output id="_D525_OUT_4" name="severity" typeRef="string" />
      <annotation name="Annotations" />
      <rule id="_D525_RULE_1">
        <inputEntry id="_D525_R1_IN_1"><text>&quot;Y&quot;</text></inputEntry>
        <outputEntry id="_D525_R1_OUT_1"><text>&quot;D000000525&quot;</text></outputEntry>
        <outputEntry id="_D525_R1_OUT_2"><text>&quot;애플워치 개통 진행&quot;</text></outputEntry>
        <outputEntry id="_D525_R1_OUT_3"><text>&quot;애플워치 자회선 개통 진행중 체크&quot;</text></outputEntry>
        <outputEntry id="_D525_R1_OUT_4"><text>&quot;STOP&quot;</text></outputEntry>
        <annotationEntry><text></text></annotationEntry>
      </rule>
      <rule id="_D525_RULE_2">
        <inputEntry id="_D525_R2_IN_1"><text>&quot;N&quot;</text></inputEntry>
        <outputEntry id="_D525_R2_OUT_1"><text>&quot;D000000525&quot;</text></outputEntry>
        <outputEntry id="_D525_R2_OUT_2"><text>&quot;애플워치 개통 미진행&quot;</text></outputEntry>
        <outputEntry id="_D525_R2_OUT_3"><text>&quot;애플워치 자회선 개통 진행중 체크&quot;</text></outputEntry>
        <outputEntry id="_D525_R2_OUT_4"><text>&quot;INFO&quot;</text></outputEntry>
        <annotationEntry><text></text></annotationEntry>
      </rule>
    </decisionTable>
  </decision>
  <inputData name="input" id="_D525_INPUT_DATA">
    <variable name="input" id="_D525_INPUT_VAR" typeRef="Any" />
  </inputData>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="_D525_DIAGRAM" name="Default DRD">
      <dmndi:DMNShape id="_D525_SHAPE_INPUT" dmnElementRef="_D525_INPUT_DATA">
        <dc:Bounds x="100" y="200" width="160" height="80" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="_D525_SHAPE_DECISION" dmnElementRef="_D525_DECISION">
        <dc:Bounds x="100" y="40" width="160" height="80" />
      </dmndi:DMNShape>
      <dmndi:DMNEdge id="_D525_EDGE" dmnElementRef="_D525_REQ" sourceElement="_D525_SHAPE_INPUT" targetElement="_D525_SHAPE_DECISION">
        <di:waypoint x="180" y="200" />
        <di:waypoint x="180" y="120" />
      </dmndi:DMNEdge>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
