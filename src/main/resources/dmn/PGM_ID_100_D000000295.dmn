<?xml version="1.0" encoding="UTF-8" ?>
<definitions xmlns="https://www.omg.org/spec/DMN/20240513/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20230324/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/" xmlns:kie="https://kie.org/dmn/extensions/1.0" expressionLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/" namespace="https://kie.apache.org/dmn/_FAA3B9D5-1FB8-47AE-BCC0-1242DDEE82A4" id="_D295_DEFINITIONS" name="_D000000295">
  <description>D000000295 처리불가이용종류체크_부가상품 (PGM_ID_100)</description>
  <itemDefinition id="_D295_VE_DEF" name="ValidationError" isCollection="false" typeLanguage="https://www.omg.org/spec/DMN/20240513/FEEL/">
    <itemComponent id="_D295_VE_C1" name="condDtlTypId">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="_D295_VE_C2" name="errorCode">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="_D295_VE_C3" name="errorMessage">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="_D295_VE_C4" name="ruleName">
      <typeRef>string</typeRef>
    </itemComponent>
    <itemComponent id="_D295_VE_C5" name="severity">
      <typeRef>string</typeRef>
      <typeConstraint id="_D295_VE_C5_CONST" kie:constraintType="enumeration">
        <text>&quot;STOP&quot;, &quot;WARN&quot;, &quot;INFO&quot;</text>
      </typeConstraint>
    </itemComponent>
  </itemDefinition>
  <decision name="_D000000295_EntryCOND" id="_D295_ENTRY_DECISION">
    <description>D295 진입조건 — 이용종류코드 (svcTypCd) 가 20~26 범위 + 권한자 아님</description>
    <variable name="_D000000295_EntryCOND" id="_D295_ENTRY_VAR" typeRef="ValidationError" />
    <informationRequirement id="_D295_ENTRY_REQ">
      <requiredInput href="#_D295_INPUT_DATA" />
    </informationRequirement>
    <decisionTable id="_D295_ENTRY_TABLE" typeRef="ValidationError" hitPolicy="UNIQUE" label="_D000000295_EntryCOND">
      <input id="_D295_E_IN_1">
        <inputExpression id="_D295_E_IN_1_EXPR" typeRef="string">
          <text>input.custService.svcTypCd</text>
        </inputExpression>
      </input>
      <input id="_D295_E_IN_2">
        <inputExpression id="_D295_E_IN_2_EXPR" typeRef="string">
          <text>input.externals.hasRoamingForceProcessAuthorityYnExt</text>
        </inputExpression>
      </input>
      <output id="_D295_E_OUT_1" name="condDtlTypId" typeRef="string" />
      <output id="_D295_E_OUT_2" name="ruleName" typeRef="string" />
      <output id="_D295_E_OUT_3" name="severity" typeRef="string" />
      <output id="_D295_E_OUT_4" name="errorMessage" typeRef="string" />
      <annotation name="Annotations" />
      <rule id="_D295_E_RULE_1">
        <inputEntry id="_D295_E_R1_IN_1">
          <text>not(&quot;20&quot;,&quot;21&quot;,&quot;22&quot;,&quot;23&quot;,&quot;24&quot;,&quot;25&quot;,&quot;26&quot;)</text>
        </inputEntry>
        <inputEntry id="_D295_E_R1_IN_2">
          <text>-</text>
        </inputEntry>
        <outputEntry id="_D295_E_R1_OUT_1">
          <text>&quot;D000000295&quot;</text>
        </outputEntry>
        <outputEntry id="_D295_E_R1_OUT_2">
          <text>&quot;처리불가이용종류체크_부가상품&quot;</text>
        </outputEntry>
        <outputEntry id="_D295_E_R1_OUT_3">
          <text>&quot;INFO&quot;</text>
        </outputEntry>
        <outputEntry id="_D295_E_R1_OUT_4">
          <text>&quot;진입조건 미충족 (SKIP)&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text>이용종류가 로밍 범위 밖 → 본 룰 적용 대상 아님 (자동 통과)</text>
        </annotationEntry>
      </rule>
      <rule id="_D295_E_RULE_2">
        <inputEntry id="_D295_E_R2_IN_1">
          <text>&quot;20&quot;,&quot;21&quot;,&quot;22&quot;,&quot;23&quot;,&quot;24&quot;,&quot;25&quot;,&quot;26&quot;</text>
        </inputEntry>
        <inputEntry id="_D295_E_R2_IN_2">
          <text>&quot;Y&quot;</text>
        </inputEntry>
        <outputEntry id="_D295_E_R2_OUT_1">
          <text>&quot;D000000295&quot;</text>
        </outputEntry>
        <outputEntry id="_D295_E_R2_OUT_2">
          <text>&quot;처리불가이용종류체크_부가상품&quot;</text>
        </outputEntry>
        <outputEntry id="_D295_E_R2_OUT_3">
          <text>&quot;INFO&quot;</text>
        </outputEntry>
        <outputEntry id="_D295_E_R2_OUT_4">
          <text>&quot;권한자 SKIP&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text>권한자는 강제처리 권한 보유 → 본 룰 SKIP</text>
        </annotationEntry>
      </rule>
      <rule id="_D295_E_RULE_3">
        <inputEntry id="_D295_E_R3_IN_1">
          <text>&quot;20&quot;,&quot;21&quot;,&quot;22&quot;,&quot;23&quot;,&quot;24&quot;,&quot;25&quot;,&quot;26&quot;</text>
        </inputEntry>
        <inputEntry id="_D295_E_R3_IN_2">
          <text>&quot;N&quot;</text>
        </inputEntry>
        <outputEntry id="_D295_E_R3_OUT_1">
          <text>&quot;D000000295&quot;</text>
        </outputEntry>
        <outputEntry id="_D295_E_R3_OUT_2">
          <text>&quot;처리불가이용종류체크_부가상품&quot;</text>
        </outputEntry>
        <outputEntry id="_D295_E_R3_OUT_3">
          <text>&quot;INFO&quot;</text>
        </outputEntry>
        <outputEntry id="_D295_E_R3_OUT_4">
          <text>&quot;진입조건 충족&quot;</text>
        </outputEntry>
        <annotationEntry>
          <text></text>
        </annotationEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision name="_D000000295" id="_D295_DECISION">
    <description>D295 본 체크 — 진입조건 통과한 케이스에 대해 chgCd, 로밍 사용여부, 가입취소여부로 STOP 판정</description>
    <variable name="_D000000295" id="_D295_DECISION_VAR" typeRef="ValidationError" />
    <informationRequirement id="_D295_REQ_ENTRY">
      <requiredDecision href="#_D295_ENTRY_DECISION" />
    </informationRequirement>
    <informationRequirement id="_D295_REQ_INPUT">
      <requiredInput href="#_D295_INPUT_DATA" />
    </informationRequirement>
