    <itemComponent id="_D298_VE_C1" name="condDtlTypId"><typeRef>string</typeRef></itemComponent>
    <itemComponent id="_D298_VE_C2" name="errorCode"><typeRef>string</typeRef></itemComponent>
    <itemComponent id="_D298_VE_C3" name="errorMessage"><typeRef>string</typeRef></itemComponent>
    <itemComponent id="_D298_VE_C4" name="ruleName"><typeRef>string</typeRef></itemComponent>
    <itemComponent id="_D298_VE_C5" name="severity">
      <typeRef>string</typeRef>
      <typeConstraint id="_D298_VE_C5_CONST" kie:constraintType="enumeration">
        <text>&quot;STOP&quot;, &quot;WARN&quot;, &quot;INFO&quot;</text>
      </typeConstraint>
    </itemComponent>
  </itemDefinition>
  <decision name="_D000000298" id="_D298_DECISION">
    <description>OMD채널제한_요금제_가입권한체크</description>
    <variable name="_D000000298" id="_D298_DECISION_VAR" typeRef="ValidationError" />
    <informationRequirement id="_D298_REQ">
      <requiredInput href="#_D298_INPUT_DATA" />
    </informationRequirement>
    <decisionTable id="_D298_TABLE" typeRef="ValidationError" hitPolicy="FIRST" label="_D000000298">
      <input id="_D298_IN_1">
        <inputExpression id="_D298_IN_1_EXPR" typeRef="string">
          <text>input.externals.hasTerminalFunctionYnExt</text>
        </inputExpression>
      </input>
      <input id="_D298_IN_2">
        <inputExpression id="_D298_IN_2_EXPR" typeRef="string">
          <text>input.externals.hasProductGroupExistYnExt</text>
        </inputExpression>
      </input>
      <input id="_D298_IN_3">
        <inputExpression id="_D298_IN_3_EXPR" typeRef="string">
          <text>input.externals.hasOmdChannelPlanJoinAuthorityYnExt</text>
        </inputExpression>
      </input>
      <input id="_D298_IN_4">
        <inputExpression id="_D298_IN_4_EXPR" typeRef="string">
          <text>input.externals.businessProcessServiceTransactionId</text>
        </inputExpression>
      </input>
      <output id="_D298_OUT_1" name="condDtlTypId" typeRef="string" />
      <output id="_D298_OUT_2" name="errorMessage" typeRef="string" />
      <output id="_D298_OUT_3" name="ruleName" typeRef="string" />
      <output id="_D298_OUT_4" name="severity" typeRef="string" />
      <annotation name="Annotations" />
      <rule id="_D298_RULE_1">
        <inputEntry id="_D298_R1_IN_1"><text>&quot;Y&quot;</text></inputEntry>
        <inputEntry id="_D298_R1_IN_2"><text>&quot;Y&quot;</text></inputEntry>
        <inputEntry id="_D298_R1_IN_3"><text>not(&quot;Y&quot;)</text></inputEntry>
        <inputEntry id="_D298_R1_IN_4"><text>not(&quot;ZORDSS0400380_TR01&quot;)</text></inputEntry>
        <outputEntry id="_D298_R1_OUT_1"><text>&quot;D000000298&quot;</text></outputEntry>
        <outputEntry id="_D298_R1_OUT_2"><text>&quot;오류 | 체크조건 미충족&quot;</text></outputEntry>
        <outputEntry id="_D298_R1_OUT_3"><text>&quot;OMD채널제한_요금제_가입권한체크&quot;</text></outputEntry>
        <outputEntry id="_D298_R1_OUT_4"><text>&quot;STOP&quot;</text></outputEntry>
        <annotationEntry><text>OMD 단말기능 + 가입불가 상품그룹 + 권한자 아님 + 예외 트랜잭션 아님 → STOP</text></annotationEntry>
      </rule>
      <rule id="_D298_RULE_2">
        <inputEntry id="_D298_R2_IN_1"><text>-</text></inputEntry>
        <inputEntry id="_D298_R2_IN_2"><text>-</text></inputEntry>
        <inputEntry id="_D298_R2_IN_3"><text>-</text></inputEntry>
        <inputEntry id="_D298_R2_IN_4"><text>-</text></inputEntry>
        <outputEntry id="_D298_R2_OUT_1"><text>&quot;D000000298&quot;</text></outputEntry>
        <outputEntry id="_D298_R2_OUT_2"><text>&quot;체크조건 충족&quot;</text></outputEntry>
        <outputEntry id="_D298_R2_OUT_3"><text>&quot;OMD채널제한_요금제_가입권한체크&quot;</text></outputEntry>
        <outputEntry id="_D298_R2_OUT_4"><text>&quot;INFO&quot;</text></outputEntry>
        <annotationEntry><text></text></annotationEntry>
      </rule>
    </decisionTable>
  </decision>
  <inputData name="input" id="_D298_INPUT_DATA">
