      <dmndi:DMNEdge id="_D298_EDGE" dmnElementRef="_D298_REQ" sourceElement="_D298_SHAPE_INPUT" targetElement="_D298_SHAPE_DECISION">
        <di:waypoint x="180" y="200" />
        <di:waypoint x="180" y="120" />
      </dmndi:DMNEdge>
    </dmndi:DMNDiagram>
