  </inputData>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="_D298_DIAGRAM" name="Default DRD">
      <dmndi:DMNShape id="_D298_SHAPE_INPUT" dmnElementRef="_D298_INPUT_DATA">
